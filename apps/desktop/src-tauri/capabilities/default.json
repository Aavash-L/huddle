{
  "$schema": "https://schema.tauri.app/schema/capability/2",
  "identifier": "default",
  "description": "Huddle Desktop default permissions",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "notification:default",
    "deep-link:default",
    "shell:allow-open",
    "window-state:allow-restore-state",
    "window-state:allow-save-window-state"
  ]
}
