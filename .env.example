NEXT_PUBLIC_ANDROID_URL=https://play.google.com/store/apps/details?id=app.huddle.mobile
# GitHub Release .dmg URL (set after first CI release):
NEXT_PUBLIC_MAC_DMG_URL=
# GitHub Release .msi / .exe URL (set after first CI release):
NEXT_PUBLIC_WINDOWS_URL=
# Deployed Expo web app URL (Vercel project for apps/mobile):
NEXT_PUBLIC_WEB_APP_URL=

# ─── Stripe ───────────────────────────────────────────────────
