{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Huddle",
  "version": "1.0.0",
  "identifier": "app.huddle.desktop",
  "build": {
    "frontendDist": "../../mobile/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Huddle",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "center": true,
        "decorations": true,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://posthog.com https://us.i.posthog.com; img-src 'self' data: https:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15",
      "entitlements": "entitlements.plist",
      "signingIdentity": null
    },
    "windows": {
      "wix": {
        "language": "en-US"
      }
    }
  },
  "plugins": {
    "notification": {},
    "deep-link": {
      "mobile": [],
      "desktop": {
        "schemes": ["huddle"]
      }
    },
    "single-instance": {},
    "window-state": {}
  }
}
