# ============================================================
# Huddle Web App — Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================================

# ─── Supabase ────────────────────────────────────────────────
# Your Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Your Supabase anon key (public)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── App Config ──────────────────────────────────────────────
# Canonical marketing site URL (used for metadata, OG tags, QR codes)
NEXT_PUBLIC_SITE_URL=https://huddle.app

# Legacy base URL (kept for compatibility)
NEXT_PUBLIC_APP_URL=https://huddle.app

# Mobile app deep link scheme
NEXT_PUBLIC_APP_SCHEME=huddle

# ─── Download targets ────────────────────────────────────────
# Leave any of these EMPTY to show a "Notify me" waitlist button instead.
# iOS App Store URL (e.g. https://apps.apple.com/app/huddle/id0000000000)
NEXT_PUBLIC_IOS_URL=

# Android Play Store URL (e.g. https://play.google.com/store/apps/details?id=app.huddle.mobile)
NEXT_PUBLIC_ANDROID_URL=

# Mac App Store URL (Apple Silicon "Designed for iPad" listing)
NEXT_PUBLIC_MAC_URL=

# Web app URL (the responder web app, or a future PWA). Empty => "Coming soon".
NEXT_PUBLIC_WEB_APP_URL=

# ─── Analytics ───────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
