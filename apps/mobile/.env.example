# ============================================================
# Huddle Mobile App — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ─── Supabase ────────────────────────────────────────────────
# Your Supabase project URL (found in Settings > API)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Your Supabase anon key (public, safe to expose in mobile apps)
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── RevenueCat ──────────────────────────────────────────────
# iOS RevenueCat API key (found in RevenueCat dashboard)
EXPO_PUBLIC_REVENUECAT_IOS_KEY=appl_...

# Android RevenueCat API key
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=goog_...

# ─── PostHog Analytics ───────────────────────────────────────
# PostHog API key (found in PostHog project settings)
EXPO_PUBLIC_POSTHOG_KEY=phc_...

# PostHog host (use cloud or self-hosted URL)
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ─── App Config ──────────────────────────────────────────────
# Deep link scheme (must match app.json scheme)
EXPO_PUBLIC_SCHEME=huddle

# Web responder base URL (where apps/web is hosted)
EXPO_PUBLIC_WEB_URL=https://huddle.app

# ─── Feature Flags ───────────────────────────────────────────
# Set to "true" to enable debug logging
EXPO_PUBLIC_DEBUG=false

# Set to "true" to bypass paywall in development
EXPO_PUBLIC_BYPASS_PAYWALL=false
