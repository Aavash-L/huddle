# ============================================================
# Huddle Web App — Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================================

# ─── Supabase ────────────────────────────────────────────────
# Your Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Your Supabase anon key (public)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── App Config ──────────────────────────────────────────────
# Base URL for the web app (used for OG meta tags)
NEXT_PUBLIC_APP_URL=https://huddle.app

# Mobile app deep link scheme
NEXT_PUBLIC_APP_SCHEME=huddle

# iOS App Store URL
NEXT_PUBLIC_IOS_URL=https://apps.apple.com/app/huddle/id0000000000

# Android Play Store URL
NEXT_PUBLIC_ANDROID_URL=https://play.google.com/store/apps/details?id=app.huddle.mobile

# ─── Analytics ───────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
