{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Huddle",
  "version": "1.0.0",
  "identifier": "app.huddle.desktop",
  "build": {
    "frontendDist": "../../mobile/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Huddle",
        "width": 1280,
        "height": 840,
        "minWidth": 960,
        "minHeight": 640,
        "center": true,
        "resizable": true,
        "visible": false,
        "backgroundColor": "#0A0E14"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15",
      "entitlements": "entitlements.plist",
      "signingIdentity": null
    },
    "windows": {
      "wix": {
        "language": "en-US"
      }
    }
  }
}
